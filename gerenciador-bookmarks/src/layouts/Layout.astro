---
interface Props {
  title?: string;
}

const { title = 'Trincheira Links' } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Repositório de Links da Trincheira.DEV" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gray-50 dark:bg-[#1c1c1c] text-gray-900 dark:text-gray-100 antialiased transition-colors">
    <slot />
  </body>
</html>
